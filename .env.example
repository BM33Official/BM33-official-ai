# LINE Messaging API — จาก LINE Developers Console > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Gemini — จาก Google AI Studio
GEMINI_API_KEY=
# โมเดล (เปลี่ยนได้โดยไม่ต้องแก้โค้ด) — free tier ใช้ flash-lite
GEMINI_MODEL=gemini-3.5-flash-lite
# ใช้ Gemini ช่วย route เมื่อ keyword ไม่ชัด (1=เปิด, 0=ปิดเพื่อประหยัด request)
USE_GEMINI_ROUTER=1

# Google Sheets API (service account) — อ่าน/เขียนชีตแบบ private
GOOGLE_SHEET_ID=1VfzrhGRURXBqbTyK7YCypq7PnLS-5JjCpjp_OAbFX34
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# ใส่ทั้ง key ในบรรทัดเดียว ครอบด้วย " และใช้ \n แทนการขึ้นบรรทัด
GOOGLE_PRIVATE_KEY=""

# สิทธิ์แอดมิน — LINE user ID คั่นด้วย , (ขึ้นต้นด้วย U)
ADMIN_LINE_USER_IDS=

# การเรียนรู้เอง (digest 3 รอบ/วัน)
# กลุ่มที่ให้บอทเรียนรู้ (groupId คั่นด้วย , ; ว่าง = ทุกกลุ่ม)
LEARN_GROUP_IDS=
# 1=ให้บอทอ่าน/สรุปรูปด้วย Gemini vision, 0=ปิด (ประหยัด request)
LEARN_IMAGES=1
# secret ที่ cron ต้องส่งมาถึงจะเรียก /api/learn ได้ (สุ่มสตริงยาว ๆ)
LEARN_CRON_SECRET=

# (optional) Smart Handoff — LINE group ID กลุ่มแอดมิน (ยังไม่ใช้ปล่อยว่างได้)
ADMIN_GROUP_ID=

# ── Control Center (ระบบบรอดแคสต์) ──
# รหัสผ่านเข้าหน้า /admin แบบแอดมินเต็ม (เห็นทุกแท็บ)
ADMIN_PANEL_PASSWORD=
# (ไม่บังคับ) รหัสผ่านฝ่ายวิชาการ — ล็อกอินด้วยรหัสนี้จะเห็น/ใช้ได้เฉพาะแท็บ "วิชาการ"
# ใช้ลิงก์เดียวกัน (/admin/login) แค่ใส่รหัสนี้ ระบบพาไปแท็บวิชาการอัตโนมัติ
ACADEMIC_PANEL_PASSWORD=
# secret ที่ cron ต้องส่งมาถึงจะสั่งส่ง broadcast ได้ (สุ่มยาว ๆ)
BROADCAST_CRON_SECRET=

# (legacy) CSV เดิม — เก็บไว้เป็น fallback ฉุกเฉิน ไม่ใช้ใน path ใหม่แล้ว
SHEET_CSV_URL=
